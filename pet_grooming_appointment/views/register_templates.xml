<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="website_register_form" model="ir.ui.view">
        <field name="name">pet.grooming.website.register.form</field>
        <field name="type">qweb</field>
        <field name="key">pet_grooming_appointment.website_register_form</field>
        <field name="arch" type="xml">
            <t t-name="pet_grooming_appointment.website_register_form">
                <t t-call="website.layout">
                    <div class="container my-5">
                        <div class="row justify-content-center">
                            <div class="col-lg-6">
                                <h1 class="mb-4">Crear cuenta</h1>

                                <t t-if="error == 'missing'">
                                    <div class="alert alert-danger">Completa todos los campos.</div>
                                </t>
                                <t t-if="error == 'password'">
                                    <div class="alert alert-danger">Las contraseñas no coinciden.</div>
                                </t>
                                <t t-if="error == 'exists'">
                                    <div class="alert alert-danger">Ya existe una cuenta con ese correo.</div>
                                </t>
                                <t t-if="error == 'send'">
                                    <div class="alert alert-danger">No se pudo enviar el código al correo.</div>
                                </t>

                                <form action="/register/send-code" method="post" class="card p-4 shadow-sm">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="mb-3">
                                        <label class="form-label">Nombre completo</label>
                                        <input type="text" name="name" class="form-control" required="required"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Correo</label>
                                        <input type="email" name="email" class="form-control" required="required"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Contraseña</label>
                                        <input type="password" name="password" class="form-control" required="required"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Confirmar contraseña</label>
                                        <input type="password" name="confirm_password" class="form-control" required="required"/>
                                    </div>

                                    <button type="submit" class="btn btn-primary">Enviar código</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <record id="website_register_verify_form" model="ir.ui.view">
        <field name="name">pet.grooming.website.register.verify.form</field>
        <field name="type">qweb</field>
        <field name="key">pet_grooming_appointment.website_register_verify_form</field>
        <field name="arch" type="xml">
            <t t-name="pet_grooming_appointment.website_register_verify_form">
                <t t-call="website.layout">
                    <div class="container my-5">
                        <div class="row justify-content-center">
                            <div class="col-lg-6">
                                <h1 class="mb-4">Verificar correo</h1>

                                <p>Te enviamos un código a: <strong><t t-out="email"/></strong></p>

                                <t t-if="error == 'invalid'">
                                    <div class="alert alert-danger">Código inválido.</div>
                                </t>
                                <t t-if="error == 'expired'">
                                    <div class="alert alert-danger">El código venció.</div>
                                </t>
                                <t t-if="error == 'server'">
                                    <div class="alert alert-danger">No se pudo completar el registro.</div>
                                </t>

                                <form action="/register/verify/submit" method="post" class="card p-4 shadow-sm">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="mb-3">
                                        <label class="form-label">Código</label>
                                        <input type="text" name="code" class="form-control" maxlength="6" required="required"/>
                                    </div>

                                    <button type="submit" class="btn btn-primary">Verificar y crear cuenta</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>
</odoo>
