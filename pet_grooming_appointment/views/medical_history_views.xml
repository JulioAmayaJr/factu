<odoo>
    <record id="view_medical_history_tree" model="ir.ui.view">
        <field name="name">pet.medical.history.tree</field>
        <field name="model">pet.medical.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="pet_id"/>
                <field name="diagnosis"/>
                <field name="veterinarian"/>
            </list>
        </field>
    </record>

    <record id="view_medical_history_form" model="ir.ui.view">
        <field name="name">pet.medical.history.form</field>
        <field name="model">pet.medical.history</field>
        <field name="arch" type="xml">
            <form string="Historial Clínico">
                <sheet>
                    <group>
                        <field name="pet_id"/>
                        <field name="date"/>
                        <field name="diagnosis"/>
                        <field name="veterinarian"/>
                    </group>
                    <group>
                        <field name="treatment"/>
                        <field name="observations"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_medical_history" model="ir.actions.act_window">
        <field name="name">Historial Clínico</field>
        <field name="res_model">pet.medical.history</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
