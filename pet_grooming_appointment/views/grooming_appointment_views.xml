<odoo>

    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">pet.grooming.appointment.tree</field>
        <field name="model">pet.grooming.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="pet_id"/>
                <field name="service_id"/>
                <field name="appointment_start"/>
                <field name="appointment_end"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">pet.grooming.appointment.form</field>
        <field name="model">pet.grooming.appointment</field>
        <field name="arch" type="xml">
            <form string="Cita Grooming">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="pet_id"/>
                            <field name="service_id"/>
                        </group>
                        <group>
                            <field name="appointment_start"/>
                            <field name="appointment_end" readonly="1"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pet_appointments" model="ir.actions.act_window">
        <field name="name">Citas</field>
        <field name="res_model">pet.grooming.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
