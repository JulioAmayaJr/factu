<odoo>

    <record id="view_service_tree" model="ir.ui.view">
        <field name="name">pet.grooming.service.tree</field>
        <field name="model">pet.grooming.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="duration_hours"/>
                <field name="price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_service_form" model="ir.ui.view">
        <field name="name">pet.grooming.service.form</field>
        <field name="model">pet.grooming.service</field>
        <field name="arch" type="xml">
            <form string="Servicio Grooming">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="duration_hours"/>
                        <field name="price"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pet_services" model="ir.actions.act_window">
        <field name="name">Servicios</field>
        <field name="res_model">pet.grooming.service</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
