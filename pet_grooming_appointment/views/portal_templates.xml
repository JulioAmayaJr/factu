<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_pets" name="Mis Mascotas">
        <t t-call="website.layout">
            <style>
                .pets-page{max-width:1200px;margin:26px auto;padding:0 12px;}
                .pets-head{display:flex;justify-content:space-between;align-items:flex-start;gap:13px;margin-bottom:22px;}
                .pets-title{font-size:38px;font-weight:900;line-height:1;color:#0f172a;margin:0;}
                .pets-sub{font-size:11px;color:#64748b;margin-top:6px;}
                .add-pet-btn{background:#f97316;color:#fff !important;padding:14px 22px;border-radius:11px;text-decoration:none;font-size:11px;font-weight:800;box-shadow:0 12px 24px rgba(249,115,22,.22);}
                .pets-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:22px;}
                .pet-list-card,.pet-add-card{background:#fff;border:1px solid #dbe3ef;border-radius:11px;overflow:hidden;box-shadow:0 6px 18px rgba(15,23,42,.04);}
                .pet-list-card img{width:100%;height:288px;object-fit:cover;display:block;}
                .pet-list-body{padding:22px;}
                .pet-type-badge{position:absolute;top:14px;right:14px;background:#fff7ed;color:#f97316;border:1px solid #fed7aa;padding:8px 18px;border-radius:999px;font-weight:800;}
                .pet-img-wrap{position:relative;}
                .pet-list-name{font-size:11px;font-weight:900;color:#0f172a;margin:0 0 4px 0;}
                .pet-list-breed{color:#64748b;font-size:11px;margin-bottom:11px;}
                .pet-view-btn{display:block;text-align:center;background:#eef2f7;color:#334155 !important;text-decoration:none;padding:13px;border-radius:11px;font-size:11px;font-weight:800;}
                .pet-add-card{border:2px dashed #cbd5e1;display:flex;align-items:center;justify-content:center;min-height:448px;background:#fafcff;}
                .pet-add-inner{text-align:center;color:#475569;}
                .pet-add-circle{width:67px;height:67px;border-radius:50%;margin:0 auto 18px auto;background:#fff1e8;color:#f97316;display:flex;align-items:center;justify-content:center;font-size:43px;line-height:1;}
                .pet-add-text{font-size:19px;font-weight:800;}

                .pet-wrap{max-width:1120px;margin:32px auto;padding:0 12px;}
                .pet-grid{display:grid;grid-template-columns:336px 1fr;gap:22px;align-items:start;}
                .pet-card,.pet-panel,.pet-note{background:#fff;border:1px solid #eceff4;border-radius:11px;box-shadow:0 8px 24px rgba(15,23,42,.05);overflow:hidden;}
                .pet-photo{height:240px;background:#f8fafc;display:flex;align-items:center;justify-content:center;overflow:hidden;}
                .pet-photo img{width:100%;height:100%;object-fit:cover;}
                .pet-body{padding:22px;}
                .pet-name{font-size:11px;font-weight:800;line-height:1.1;margin:0 0 6px 0;color:#0f172a;}
                .pet-sub{font-size:11px;color:#64748b;margin-bottom:16px;}
                .pet-badge{display:inline-block;background:#3b82f6;color:#fff;padding:5px 11px;border-radius:999px;font-weight:700;font-size:10px;}
                .pet-mini-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:14px;}
                .pet-mini{background:#f8fafc;border:1px solid #e5e7eb;border-radius:13px;padding:13px;}
                .pet-mini-label{font-size:10px;text-transform:uppercase;color:#94a3b8;font-weight:700;margin-bottom:6px;}
                .pet-mini-value{font-size:13px;font-weight:700;color:#1e293b;}
                .pet-edit-btn{display:block;background:#07163a;color:#fff !important;text-decoration:none;text-align:center;border-radius:13px;padding:13px;font-size:11px;font-weight:800;margin-top:16px;}
                .pet-note{margin-top:16px;background:#fff8e8;border-color:#f2d59a;}
                .pet-note .pet-body{color:#9a4c12;}
                .panel-head{display:flex;justify-content:space-between;align-items:center;padding:18px 21px;border-bottom:1px solid #eef2f7;}
                .panel-title{font-size:13px;font-weight:800;color:#1e293b;margin:0;}
                .timeline{padding:14px 21px 19px 21px;}
                .time-item{position:relative;padding-left:44px;padding-bottom:26px;}
                .time-item:last-child{padding-bottom:0;}
                .time-item:before{content:"";position:absolute;left:14px;top:8px;bottom:-8px;width:2px;background:#e5e7eb;}
                .time-item:last-child:before{display:none;}
                .time-dot{position:absolute;left:2px;top:6px;width:19px;height:19px;border-radius:50%;background:#dbeafe;border:6px solid #93c5fd;}
                .time-title{font-size:11px;font-weight:800;color:#1e293b;}
                .time-meta{color:#64748b;}
                .time-date{position:absolute;right:0;top:0;color:#94a3b8;font-weight:700;}
                .table-wrap{padding:0 0 8px 0;}
                .pet-table{width:100%;border-collapse:collapse;}
                .pet-table th,.pet-table td{padding:14px 21px;border-bottom:1px solid #eef2f7;vertical-align:top;}
                .pet-table th{font-size:10px;text-transform:uppercase;color:#94a3b8;font-weight:800;}
                .status-pill{display:inline-block;padding:5px 10px;border-radius:999px;background:#dcfce7;color:#166534;font-weight:800;font-size:11px;}
                .pet-section-space{margin-bottom:22px;}

                .pet-form-page{max-width:784px;margin:26px auto;padding:0 12px;}
                .pet-form-title{font-size:42px;font-weight:900;line-height:1;color:#0f172a;margin:0;}
                .pet-form-sub{font-size:13px;color:#64748b;margin:10px 0 28px 0;}
                .pet-upload-box{position:relative;border:2px dashed #d7dde7;border-radius:11px;overflow:hidden;background:#f8fafc;height:232px;display:flex;align-items:center;justify-content:center;margin-bottom:21px;}
                .pet-upload-preview{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
                .pet-upload-overlay{position:absolute;inset:0;background:rgba(255,255,255,.55);}
                .pet-upload-content{position:relative;z-index:2;text-align:center;}
                .pet-upload-icon{width:38px;height:38px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#f97316;color:#fff;font-size:11px;font-weight:900;margin-bottom:8px;}
                .pet-upload-title{font-size:19px;font-weight:800;color:#0f172a;}
                .pet-upload-sub{font-size:11px;color:#64748b;margin:8px 0 14px 0;}
                .pet-upload-btn{display:inline-block;background:#f97316;color:#fff !important;text-decoration:none;padding:10px 18px;border-radius:10px;font-weight:800;position:relative;overflow:hidden;}
                .pet-upload-btn input{position:absolute;inset:0;opacity:0;cursor:pointer;}
                .pet-form-section{margin-bottom:19px;}
                .pet-form-card{background:#fff;border:1px solid #ebeef5;border-radius:11px;padding:21px;box-shadow:0 8px 20px rgba(15,23,42,.04);}
                .pet-form-section-title{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:900;color:#0f172a;margin:0 0 18px 0;}
                .pet-form-section-dot{color:#f97316;font-size:11px;}
                .pet-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 18px;}
                .pet-field label{display:block;font-size:11px;font-weight:800;color:#475569;margin-bottom:8px;}
                .pet-field input,.pet-field select,.pet-field textarea{width:100%;border:1px solid #e2e8f0;border-radius:10px;padding:11px 13px;font-size:13px;color:#0f172a;background:#fff;}
                .pet-field textarea{min-height:88px;resize:vertical;}
                .pet-full{grid-column:1 / -1;}
                .pet-check-wrap{display:flex;gap:26px;align-items:center;padding-top:8px;}
                .pet-check{display:flex;align-items:center;gap:8px;font-weight:700;color:#475569;}
                .pet-form-actions{display:flex;align-items:center;gap:22px;margin-top:28px;}
                .pet-save-btn{background:#f97316;color:#fff !important;text-decoration:none;border:none;padding:13px 22px;border-radius:11px;font-size:11px;font-weight:900;box-shadow:0 12px 24px rgba(249,115,22,.24);}
                .pet-cancel-link{color:#64748b !important;text-decoration:none;font-weight:700;}

                .appt-page{max-width:816px;margin:26px auto;padding:0 12px;}
                .appt-header{display:flex;align-items:center;gap:14px;margin-bottom:19px;}
                .appt-back{color:#f97316 !important;text-decoration:none;font-size:27px;line-height:1;font-weight:900;}
                .appt-title{font-size:38px;font-weight:900;color:#0f172a;margin:0;}
                .appt-card{background:#fff;border:1px solid #e5eaf2;border-radius:11px;padding:22px;box-shadow:0 8px 22px rgba(15,23,42,.05);}
                .appt-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 19px;}
                .appt-field{grid-column:span 2;}
                .appt-half{grid-column:span 1;}
                .appt-field label{display:block;font-size:11px;font-weight:800;color:#475569;margin-bottom:8px;}
                .appt-field input,.appt-field select,.appt-field textarea{width:100%;border:1px solid #dbe3ef;border-radius:13px;padding:14px 14px;font-size:11px;color:#0f172a;background:#fff;}
                .appt-field textarea{min-height:112px;resize:vertical;}
                .appt-submit{width:100%;margin-top:16px;background:#f97316;color:#fff;border:none;border-radius:13px;padding:18px;font-size:11px;font-weight:900;box-shadow:0 12px 24px rgba(249,115,22,.24);}
                @media (max-width: 1100px){.pets-grid{grid-template-columns:repeat(2,minmax(0,1fr));}}
                @media (max-width: 980px){.pet-grid{grid-template-columns:1fr;}}
                @media (max-width: 768px){.pets-grid,.pet-form-grid,.appt-grid{grid-template-columns:1fr;}.appt-field,.appt-half,.pet-full{grid-column:auto;}.pets-head{flex-direction:column;}.pets-title,.appt-title,.pet-form-title{font-size:29px;}}
            </style>

            <div class="pets-page">
                <div class="pets-head">
                    <div>
                        <h1 class="pets-title">Mis Mascotas</h1>
                        <div class="pets-sub">Administra y da seguimiento a tus mascotas en un solo lugar</div>
                    </div>
                    <a href="/my/pets/new" class="add-pet-btn">➕ Agregar Mascota</a>
                </div>

                <div class="pets-grid">
                    <t t-foreach="pets" t-as="pet">
                        <div class="pet-list-card">
                            <div class="pet-img-wrap">
                                <t t-if="pet.image_1920">
                                    <img t-att-src="'/web/image/pet.animal/%s/image_1920' % pet.id"/>
                                </t>
                                <t t-else="">
                                    <img t-att-src="pet.default_image_url"/>
                                </t>
                                <span class="pet-type-badge">
                                    <t t-out="'Perro' if pet.species == 'dog' else ('Gato' if pet.species == 'cat' else 'Mascota')"/>
                                </span>
                            </div>
                            <div class="pet-list-body">
                                <div class="pet-list-name"><t t-out="pet.name"/></div>
                                <div class="pet-list-breed"><t t-out="pet.breed or '-'"/></div>
                                <a t-att-href="'/my/pets/%s' % pet.id" class="pet-view-btn">Ver Perfil</a>
                            </div>
                        </div>
                    </t>

                    <a href="/my/pets/new" class="pet-add-card" style="text-decoration:none;">
                        <div class="pet-add-inner">
                            <div class="pet-add-circle">+</div>
                            <div class="pet-add-text">Agregar otra mascota</div>
                        </div>
                    </a>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_pet_form" name="Formulario Mascota">
        <t t-call="website.layout">
            <style>
                .pet-form-page{max-width:784px;margin:26px auto;padding:0 12px;}
                .pet-form-title{font-size:42px;font-weight:900;line-height:1;color:#0f172a;margin:0;}
                .pet-form-sub{font-size:13px;color:#64748b;margin:10px 0 28px 0;}
                .pet-upload-box{position:relative;border:2px dashed #d7dde7;border-radius:11px;overflow:hidden;background:#f8fafc;height:232px;display:flex;align-items:center;justify-content:center;margin-bottom:21px;}
                .pet-upload-preview{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
                .pet-upload-overlay{position:absolute;inset:0;background:rgba(255,255,255,.55);}
                .pet-upload-content{position:relative;z-index:2;text-align:center;}
                .pet-upload-icon{width:38px;height:38px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:#f97316;color:#fff;font-size:11px;font-weight:900;margin-bottom:8px;}
                .pet-upload-title{font-size:19px;font-weight:800;color:#0f172a;}
                .pet-upload-sub{font-size:11px;color:#64748b;margin:8px 0 14px 0;}
                .pet-upload-btn{display:inline-block;background:#f97316;color:#fff !important;text-decoration:none;padding:10px 18px;border-radius:10px;font-weight:800;position:relative;overflow:hidden;}
                .pet-upload-btn input{position:absolute;inset:0;opacity:0;cursor:pointer;}
                .pet-form-section{margin-bottom:19px;}
                .pet-form-card{background:#fff;border:1px solid #ebeef5;border-radius:11px;padding:21px;box-shadow:0 8px 20px rgba(15,23,42,.04);}
                .pet-form-section-title{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:900;color:#0f172a;margin:0 0 18px 0;}
                .pet-form-section-dot{color:#f97316;font-size:11px;}
                .pet-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 18px;}
                .pet-field label{display:block;font-size:11px;font-weight:800;color:#475569;margin-bottom:8px;}
                .pet-field input,.pet-field select,.pet-field textarea{width:100%;border:1px solid #e2e8f0;border-radius:10px;padding:11px 13px;font-size:13px;color:#0f172a;background:#fff;}
                .pet-field textarea{min-height:88px;resize:vertical;}
                .pet-full{grid-column:1 / -1;}
                .pet-check-wrap{display:flex;gap:26px;align-items:center;padding-top:8px;}
                .pet-check{display:flex;align-items:center;gap:8px;font-weight:700;color:#475569;}
                .pet-form-actions{display:flex;align-items:center;gap:22px;margin-top:28px;}
                .pet-save-btn{background:#f97316;color:#fff !important;text-decoration:none;border:none;padding:13px 22px;border-radius:11px;font-size:11px;font-weight:900;box-shadow:0 12px 24px rgba(249,115,22,.24);}
                .pet-cancel-link{color:#64748b !important;text-decoration:none;font-weight:700;}
                @media (max-width: 768px){.pet-form-grid{grid-template-columns:1fr;}.pet-full{grid-column:auto;}.pet-form-title{font-size:29px;}}
            </style>

            <div class="pet-form-page">
                <h1 class="pet-form-title">
                    <t t-out="'Editar perfil de mascota' if pet else 'Registrar tu mascota'"/>
                </h1>
                <div class="pet-form-sub">
                    Cuéntanos sobre tu compañero para empezar con el mejor cuidado personalizado.
                </div>

                <t t-if="error">
                    <div class="alert alert-danger mb-4">No se pudo guardar la mascota.</div>
                </t>

                <form t-att-action="form_action" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="pet-upload-box">
                        <t t-if="pet and pet.image_1920">
                            <img t-att-src="'/web/image/pet.animal/%s/image_1920' % pet.id" class="pet-upload-preview"/>
                        </t>
                        <t t-elif="pet">
                            <img t-att-src="pet.default_image_url" class="pet-upload-preview"/>
                        </t>
                        <div class="pet-upload-overlay"></div>
                        <div class="pet-upload-content">
                            <div class="pet-upload-icon">📷</div>
                            <div class="pet-upload-title">Subir foto de la mascota</div>
                            <div class="pet-upload-sub">Arrastra una imagen o selecciona una foto de buena calidad</div>
                            <label class="pet-upload-btn">
                                Seleccionar imagen
                                <input type="file" name="image" accept="image/*"/>
                            </label>
                        </div>
                    </div>

                    <div class="pet-form-section">
                        <div class="pet-form-card">
                            <h2 class="pet-form-section-title"><span class="pet-form-section-dot">●</span>Información básica</h2>
                            <div class="pet-form-grid">
                                <div class="pet-field">
                                    <label>Nombre de la mascota</label>
                                    <input type="text" name="name" required="required" placeholder="Ej. Buddy" t-att-value="pet.name if pet else ''"/>
                                </div>

                                <div class="pet-field">
                                    <label>Especie</label>
                                    <select name="species">
                                        <option value="dog" t-att-selected="'selected' if pet and pet.species == 'dog' else None">Perro</option>
                                        <option value="cat" t-att-selected="'selected' if pet and pet.species == 'cat' else None">Gato</option>
                                        <option value="other" t-att-selected="'selected' if pet and pet.species == 'other' else None">Otro</option>
                                    </select>
                                </div>

                                <div class="pet-field">
                                    <label>Raza</label>
                                    <input type="text" name="breed" placeholder="Ej. Golden Retriever" t-att-value="pet.breed if pet else ''"/>
                                </div>

                                <div class="pet-field">
                                    <label>Género</label>
                                    <div class="pet-check-wrap">
                                        <label class="pet-check">
                                            <input type="radio" name="sex" value="male" t-att-checked="'checked' if pet and pet.sex == 'male' else None"/>
                                            Macho
                                        </label>
                                        <label class="pet-check">
                                            <input type="radio" name="sex" value="female" t-att-checked="'checked' if pet and pet.sex == 'female' else None"/>
                                            Hembra
                                        </label>
                                    </div>
                                </div>

                                <div class="pet-field">
                                    <label>Color principal</label>
                                    <input type="text" name="color" placeholder="Ej. Dorado, Negro" t-att-value="pet.color if pet else ''"/>
                                </div>

                                <div class="pet-field">
                                    <label>Peso (kg)</label>
                                    <input type="number" step="0.01" name="weight" placeholder="0.0" t-att-value="pet.weight if pet else ''"/>
                                </div>

                                <div class="pet-field">
                                    <label>Fecha de nacimiento</label>
                                    <input type="date" name="birthdate" t-att-value="pet.birthdate if pet and pet.birthdate else ''"/>
                                </div>

                                <div class="pet-field">
                                    <label>Edad</label>
                                    <input type="text" name="age_text" placeholder="Ej. 4 años" t-att-value="pet.age_text if pet else ''"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="pet-form-section">
                        <div class="pet-form-card" style="background:#fff7f2;">
                            <h2 class="pet-form-section-title"><span class="pet-form-section-dot">●</span>Salud y estado</h2>
                            <div class="pet-check-wrap">
                                <label class="pet-check">
                                    <input type="checkbox" name="is_vaccinated" t-att-checked="'checked' if pet and pet.is_vaccinated else None"/>
                                    Vacunado
                                </label>
                                <label class="pet-check">
                                    <input type="checkbox" name="sterilized" t-att-checked="'checked' if pet and pet.sterilized else None"/>
                                    Esterilizado / Castrado
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="pet-form-section">
                        <div class="pet-form-card">
                            <h2 class="pet-form-section-title"><span class="pet-form-section-dot">●</span>Historial médico</h2>
                            <div class="pet-form-grid">
                                <div class="pet-field pet-full">
                                    <label>Historial de vacunación</label>
                                    <textarea name="vaccine_notes" placeholder="Lista vacunas recientes y fechas..."><t t-out="pet.vaccine_notes if pet else ''"/></textarea>
                                </div>

                                <div class="pet-field pet-full">
                                    <label>Alergias</label>
                                    <textarea name="allergies" placeholder="Lista alergias alimentarias o ambientales..."><t t-out="pet.allergies if pet else ''"/></textarea>
                                </div>

                                <div class="pet-field pet-full">
                                    <label>Notas médicas</label>
                                    <textarea name="medical_notes" placeholder="Condiciones actuales, cirugías previas o notas de comportamiento..."><t t-out="pet.medical_notes if pet else ''"/></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="pet-form-section">
                        <div class="pet-form-card">
                            <h2 class="pet-form-section-title"><span class="pet-form-section-dot">●</span>Notas generales</h2>
                            <div class="pet-field">
                                <textarea name="notes" placeholder="¿Algo más que debamos saber sobre la personalidad o preferencias de tu mascota?"><t t-out="pet.notes if pet else ''"/></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="pet-form-actions">
                        <button type="submit" class="pet-save-btn">
                            <t t-out="'Guardar perfil de mascota' if not pet else 'Guardar cambios'"/>
                        </button>
                        <a href="/my/pets" class="pet-cancel-link">Cancelar</a>
                    </div>
                </form>
            </div>
        </t>
    </template>

