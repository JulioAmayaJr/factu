                .pet-mini-value{font-size:13px;font-weight:700;color:#1e293b;}
                .pet-edit-btn{display:block;background:#07163a;color:#fff !important;text-decoration:none;text-align:center;border-radius:13px;padding:13px;font-size:11px;font-weight:800;margin-top:16px;}
                .pet-note{margin-top:16px;background:#fff8e8;border-color:#f2d59a;}
                .pet-note .pet-body{color:#9a4c12;}
                .panel-head{display:flex;justify-content:space-between;align-items:center;padding:18px 21px;border-bottom:1px solid #eef2f7;}
                .panel-title{font-size:13px;font-weight:800;color:#1e293b;margin:0;}
                .timeline{padding:14px 21px 19px 21px;}
                .time-item{position:relative;padding-left:44px;padding-bottom:26px;}
                .time-item:last-child{padding-bottom:0;}
                .time-item:before{content:"";position:absolute;left:14px;top:8px;bottom:-8px;width:2px;background:#e5e7eb;}
                .time-item:last-child:before{display:none;}
                .time-dot{position:absolute;left:2px;top:6px;width:19px;height:19px;border-radius:50%;background:#dbeafe;border:6px solid #93c5fd;}
                .time-title{font-size:11px;font-weight:800;color:#1e293b;}
                .time-meta{color:#64748b;}
                .time-date{position:absolute;right:0;top:0;color:#94a3b8;font-weight:700;}
                .table-wrap{padding:0 0 8px 0;}
                .pet-table{width:100%;border-collapse:collapse;}
                .pet-table th,.pet-table td{padding:14px 21px;border-bottom:1px solid #eef2f7;vertical-align:top;}
                .pet-table th{font-size:10px;text-transform:uppercase;color:#94a3b8;font-weight:800;}
                .status-pill{display:inline-block;padding:5px 10px;border-radius:999px;background:#dcfce7;color:#166534;font-weight:800;font-size:11px;}
                .pet-section-space{margin-bottom:22px;}
                @media (max-width: 980px){.pet-grid{grid-template-columns:1fr;}}
            </style>

            <div class="pet-wrap">
                <div class="pet-grid">
                    <div>
                        <div class="pet-card">
                            <div class="pet-photo">
                                <t t-if="pet.image_1920">
                                    <img t-att-src="'/web/image/pet.animal/%s/image_1920' % pet.id"/>
                                </t>
                                <t t-else="">
                                    <img t-att-src="pet.default_image_url"/>
                                </t>
                            </div>
                            <div class="pet-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div></div>
                                    <span class="pet-badge">ACTIVA</span>
                                </div>

                                <h1 class="pet-name"><t t-out="pet.name"/></h1>
                                <div class="pet-sub">
                                    <t t-out="'Perro' if pet.species == 'dog' else ('Gato' if pet.species == 'cat' else 'Mascota')"/>
                                    <t t-if="pet.breed"> (<t t-out="pet.breed"/>)</t>
                                </div>

                                <div class="pet-mini-grid">
                                    <div class="pet-mini">
                                        <div class="pet-mini-label">Sexo</div>
                                        <div class="pet-mini-value">
                                            <t t-out="'Hembra' if pet.sex == 'female' else ('Macho' if pet.sex == 'male' else '-')"/>
                                        </div>
                                    </div>
                                    <div class="pet-mini">
                                        <div class="pet-mini-label">Peso</div>
                                        <div class="pet-mini-value"><t t-out="('%0.1f kg' % pet.weight) if pet.weight else '-'"/></div>
                                    </div>
                                    <div class="pet-mini">
                                        <div class="pet-mini-label">Color</div>
                                        <div class="pet-mini-value"><t t-out="pet.color or '-'"/></div>
                                    </div>
                                    <div class="pet-mini">
                                        <div class="pet-mini-label">Edad</div>
                                        <div class="pet-mini-value"><t t-out="pet.age_text or '-'"/></div>
                                    </div>
                                </div>

                                <a t-att-href="'/my/pets/%s/edit' % pet.id" class="pet-edit-btn">Editar Perfil</a>
                            </div>
                        </div>

                        <div class="pet-note">
                            <div class="pet-body">
                                <div style="font-weight:800; margin-bottom:12px;">NOTAS ESPECIALES</div>
                                <div><t t-out="pet.notes or pet.medical_notes or 'Sin notas especiales.'"/></div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="pet-panel pet-section-space">
                            <div class="panel-head">
                                <h3 class="panel-title">Historial de Baños y Corte</h3>
                                <a href="/my/pet-grooming/book" style="font-weight:700; text-decoration:none;">Nueva cita</a>
                            </div>
                            <div class="timeline">
                                <t t-if="appointments">
                                    <t t-foreach="appointments" t-as="item">
                                        <div class="time-item">
                                            <div class="time-dot"></div>
                                            <div class="time-date">
                                                <t t-out="item.appointment_start.strftime('%d/%m/%Y %H:%M') if item.appointment_start else ''"/>
                                            </div>
                                            <div class="time-title">
                                                <t t-out="item.service_id.name if item.service_id else 'Servicio'"/>
                                            </div>
                                            <div class="time-meta">
                                                Estado:
                                                <t t-out="'Confirmada' if item.state == 'confirmed' else ('Completada' if item.state == 'done' else ('Cancelada' if item.state == 'cancelled' else 'Borrador'))"/>
                                                <t t-if="item.notes">
                                                    <br/>
                                                    <t t-out="item.notes"/>
                                                </t>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="text-muted">No hay citas registradas todavía.</div>
                                </t>
                            </div>
                        </div>

                        <div class="pet-panel">
                            <div class="panel-head">
                                <h3 class="panel-title">Historial Clínico</h3>
                                <span style="font-weight:700; color:#2563eb;">Registros</span>
                            </div>

                            <div class="table-wrap">
                                <table class="pet-table">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Tipo de registro</th>
                                            <th>Veterinario / Notas</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="medical_history">
                                            <t t-foreach="medical_history" t-as="item">
                                                <tr>
                                                    <td><t t-out="item.date or ''"/></td>
                                                    <td>
                                                        <div style="font-weight:800;"><t t-out="item.diagnosis or '-'"/></div>
                                                        <div style="color:#94a3b8;"><t t-out="item.treatment or ''"/></div>
                                                    </td>
                                                    <td>
                                                        <div><t t-out="item.veterinarian or '-'"/></div>
                                                        <div style="color:#94a3b8;"><t t-out="item.observations or ''"/></div>
                                                    </td>
                                                    <td><span class="status-pill">Completado</span></td>
                                                </tr>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <tr>
                                                <td colspan="4" class="text-center text-muted">No hay historial clínico todavía.</td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_book_appointment" name="Agendar Cita">
        <t t-call="website.layout">
            <style>
                .appt-page{max-width:816px;margin:26px auto;padding:0 12px;}
                .appt-header{display:flex;align-items:center;gap:14px;margin-bottom:19px;}
                .appt-back{color:#f97316 !important;text-decoration:none;font-size:27px;line-height:1;font-weight:900;}
                .appt-title{font-size:38px;font-weight:900;color:#0f172a;margin:0;}
                .appt-card{background:#fff;border:1px solid #e5eaf2;border-radius:11px;padding:22px;box-shadow:0 8px 22px rgba(15,23,42,.05);}
                .appt-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 19px;}
                .appt-field{grid-column:span 2;}
                .appt-half{grid-column:span 1;}
                .appt-field label{display:block;font-size:11px;font-weight:800;color:#475569;margin-bottom:8px;}
                .appt-field input,.appt-field select,.appt-field textarea{width:100%;border:1px solid #dbe3ef;border-radius:13px;padding:14px 14px;font-size:11px;color:#0f172a;background:#fff;}
                .appt-field textarea{min-height:112px;resize:vertical;}
                .appt-submit{width:100%;margin-top:16px;background:#f97316;color:#fff;border:none;border-radius:13px;padding:18px;font-size:11px;font-weight:900;box-shadow:0 12px 24px rgba(249,115,22,.24);}
                @media (max-width: 768px){.appt-grid{grid-template-columns:1fr;}.appt-field,.appt-half{grid-column:auto;}.appt-title{font-size:29px;}}
            </style>

            <div class="appt-page">
                <div class="appt-header">
                    <a href="/my/pets" class="appt-back">←</a>
                    <h1 class="appt-title">Agendar cita</h1>
                </div>

                <t t-if="success">
                    <div class="alert alert-success mb-4">Tu cita fue registrada correctamente.</div>
                </t>

                <t t-if="error">
                    <div class="alert alert-danger mb-4">No se pudo registrar la cita.</div>
                </t>

                <form action="/my/pet-grooming/book/submit" method="post" class="appt-card">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="appt-grid">
                        <div class="appt-field">
                            <label>Mascota</label>
                            <select name="pet_id" required="required">
                                <option value="">Seleccionar mascota</option>
                                <t t-foreach="pets" t-as="pet">
                                    <option t-att-value="pet.id"><t t-out="pet.name"/></option>
                                </t>
                            </select>
                        </div>

                        <div class="appt-field">
                            <label>Servicio</label>
                            <select name="service_id" required="required">
                                <option value="">Seleccionar tipo de servicio</option>
                                <t t-foreach="services" t-as="service">
                                    <option t-att-value="service.id"><t t-out="service.name"/></option>
                                </t>
                            </select>
                        </div>

                        <div class="appt-half">
                            <label>Fecha</label>
                            <input type="date" name="date" required="required"/>
                        </div>

                        <div class="appt-half">
                            <label>Hora</label>
                            <input type="time" name="hour" required="required"/>
                        </div>

                        <div class="appt-field">
                            <label>Notas adicionales</label>
                            <textarea name="notes" placeholder="Ej. Alergias, comportamiento especial, servicios adicionales..."></textarea>
                        </div>
                    </div>

                    <button type="submit" class="appt-submit">📅 Agendar</button>
                </form>
            </div>
        </t>
    </template>

    <template id="portal_my_appointments" name="Mis Citas">
        <t t-call="website.layout">
            <div class="container my-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1>Mis Citas</h1>
                    <a href="/my/pet-grooming/book" class="btn btn-primary">Nueva cita</a>
                </div>

                <div class="card p-3 shadow-sm">
                    <t t-foreach="appointments" t-as="item">
                        <div class="border-bottom py-3">
                            <strong><t t-out="item.pet_id.name if item.pet_id else '-'"/></strong> -
                            <t t-out="item.service_id.name if item.service_id else '-'"/> -
                            <t t-out="item.appointment_start"/> -
                            <t t-out="item.state"/>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
