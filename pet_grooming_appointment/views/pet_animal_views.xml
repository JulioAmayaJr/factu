<odoo>
    <record id="view_pet_animal_tree" model="ir.ui.view">
        <field name="name">pet.animal.tree</field>
        <field name="model">pet.animal</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="species"/>
                <field name="breed"/>
            </list>
        </field>
    </record>

    <record id="view_pet_animal_form" model="ir.ui.view">
        <field name="name">pet.animal.form</field>
        <field name="model">pet.animal</field>
        <field name="arch" type="xml">
            <form string="Mascota">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="species"/>
                            <field name="breed"/>
                            <field name="birthdate"/>
                        </group>
                        <group>
                            <field name="color"/>
                            <field name="sex"/>
                            <field name="weight"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <notebook>
                        <page string="Historial Clínico">
                            <field name="medical_history_ids"/>
                        </page>
                        <page string="Historial Grooming">
                            <field name="grooming_history_ids"/>
                        </page>
                        <page string="Citas">
                            <field name="appointment_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pet_animals" model="ir.actions.act_window">
        <field name="name">Mascotas</field>
        <field name="res_model">pet.animal</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
