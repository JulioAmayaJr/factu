<odoo>
    <record id="view_grooming_history_tree" model="ir.ui.view">
        <field name="name">pet.grooming.history.tree</field>
        <field name="model">pet.grooming.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="pet_id"/>
                <field name="service_id"/>
                <field name="hairstyle"/>
            </list>
        </field>
    </record>

    <record id="view_grooming_history_form" model="ir.ui.view">
        <field name="name">pet.grooming.history.form</field>
        <field name="model">pet.grooming.history</field>
        <field name="arch" type="xml">
            <form string="Historial Grooming">
                <sheet>
                    <group>
                        <field name="pet_id"/>
                        <field name="appointment_id"/>
                        <field name="date"/>
                        <field name="service_id"/>
                        <field name="hairstyle"/>
                    </group>
                    <group>
                        <field name="bath_done"/>
                        <field name="haircut_done"/>
                        <field name="nails_done"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_grooming_history" model="ir.actions.act_window">
        <field name="name">Historial Grooming</field>
        <field name="res_model">pet.grooming.history</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
